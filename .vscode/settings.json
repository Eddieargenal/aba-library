{
  "workbench.colorTheme": "Dark Modern",
  "workbench.iconTheme": "vs-seti",
  "workbench.colorCustomizations": {
    "editor.background": "#1e1e1ef2",
    "sideBar.background": "#181818f2",
    "panel.background": "#141414f2",
    "terminal.background": "#111111f2"
  },
  "window.titleBarStyle": "custom",
  "window.commandCenter": false,
  "window.zoomLevel": 0,

  "workbench.startupEditor": "none",
  "workbench.editor.enablePreview": false,
  "workbench.editor.enablePreviewFromQuickOpen": false,
  "workbench.editor.wrapTabs": true,
  "workbench.editor.tabSizing": "shrink",
  "workbench.editor.highlightModifiedTabs": true,

  "workbench.tree.indent": 16,
  "workbench.list.smoothScrolling": true,

  "explorer.compactFolders": false,
  "explorer.confirmDragAndDrop": false,

  "breadcrumbs.enabled": true,

  "editor.minimap.enabled": false,
  "editor.renderWhitespace": "selection",
  "editor.renderControlCharacters": false,
  "editor.scrollBeyondLastLine": false,
  "editor.stickyScroll.enabled": true,
  "editor.fontSize": 14,
  "editor.fontWeight": 500,
  "editor.lineHeight": 19,
  "editor.fontLigatures": true,
  "editor.fontVariations": true,
  "editor.fontFamily": "JetBrains Mono, Cascadia Code, Menlo, Monaco, 'Courier New', monospace",
  "editor.cursorStyle": "block",
  "editor.cursorBlinking": "blink",
  "editor.cursorSmoothCaretAnimation": "on",
  "editor.bracketPairColorization.enabled": true,
  "editor.guides.bracketPairs": true,
  "editor.guides.indentation": true,
  "editor.guides.highlightActiveIndentation": true,
  "editor.smoothScrolling": true,

  "scm.diffDecorations": "gutter",

  "terminal.integrated.fontFamily": "JetBrains Mono, Cascadia Code, Menlo, Monaco, 'Courier New', monospace",
  "terminal.integrated.fontSize": 14,
  "terminal.integrated.fontWeight": "500",
  "terminal.integrated.fontLigatures.enabled": true,
  "terminal.integrated.lineHeight": 1.35,
  "terminal.integrated.cursorStyle": "block",
  "terminal.integrated.cursorBlinking": true,
  "terminal.integrated.scrollback": 15000,
  "terminal.integrated.defaultLocation": "editor",
  "terminal.integrated.smoothScrolling": true,

  "debug.console.fontSize": 13,

  "notebook.output.scrolling": true,

  "workbench.fontAliasing": "antialiased",

  "chat.fontFamily": "JetBrains Mono, Cascadia Code, Menlo, Monaco, 'Courier New', monospace",
  "chat.fontSize": 14,
  "chat.editor.fontFamily": "JetBrains Mono, Cascadia Code, Menlo, Monaco, 'Courier New', monospace",
  "chat.editor.fontSize": 14,
  "chat.editor.fontWeight": "500"
}
